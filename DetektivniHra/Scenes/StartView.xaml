<UserControl x:Class="DetektivniHra.Scenes.StartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Grid Background="#111111">

		<StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="600">

			<TextBlock Text="ZMIZELÝ KUFŘÍK"
                       Foreground="White"
                       FontSize="48"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0,0,0,20"/>

			<TextBlock Text="Detektivní klikací adventura"
                       Foreground="LightGray"
                       FontSize="22"
                       TextAlignment="Center"
                       Margin="0,0,0,40"/>

			<TextBlock Text="Jsi detektiv a tvým úkolem je najít ztracený kufřík s důkazy. Prozkoumej místa, najdi stopy a vyřeš případ. "
                       Foreground="White"
                       FontSize="18"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,0,0,10"/>
            <TextBlock Text="Pro správné fungování hry použij fullscreen!"
                       Foreground="Red"
                       FontSize="12"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,0,0,40" Height="20"/>

            <Button Content="Začít hru"
                    Width="220"
                    Height="55"
                    FontSize="22"
                    Click="StartGame_Click"/>

		</StackPanel>

	</Grid>
</UserControl>