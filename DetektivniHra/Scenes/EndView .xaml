<UserControl x:Class="DetektivniHra.Scenes.EndView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#111111">

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="600">

            <TextBlock Text="PŘÍPAD VYŘEŠEN"
                       Foreground="White"
                       FontSize="48"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Našel jsi ztracený kufřík s důkazy."
                       Foreground="LightGray"
                       FontSize="24"
                       TextAlignment="Center"
                       Margin="0,0,0,30"/>

            <TextBlock Text="Detektiv úspěšně dokončil případ. Pachatel byl odhalen a důkazy jsou v bezpečí."
                       Foreground="White"
                       FontSize="18"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,0,0,40"/>

            <Button Content="Hrát znovu"
                    Width="140"
                    Height="45"
                    FontSize="22"
                    Click="Restart_Click"/>

        </StackPanel>

    </Grid>
</UserControl>