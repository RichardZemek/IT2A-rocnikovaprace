<UserControl x:Class="DetektivniHra.Scenes.ApartmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>

        <!-- Pozadí -->
        <Image Source="/Assets/Backgrounds/apartment.png" Stretch="Fill"/>

        <!-- Notebook -->
        <Button Width="208"
                Height="140"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="410,0,0,484"
                Click="Computer_Click"
                Background="Transparent"
                Opacity="0.01"
                Cursor="Hand"
                BorderThickness="0" RenderTransformOrigin="0.5,0.5">
            <Button.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="0.055"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Button.RenderTransform>

            <Image Source="pack://application:,,,/Assets/Objects/computer.png"
                   Stretch="Uniform" Height="163" Width="171" RenderTransformOrigin="0.508,0.397">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform AngleX="-0.001"/>
                        <RotateTransform/>
                        <TranslateTransform X="-0.001"/>
                    </TransformGroup>
                </Image.RenderTransform>
            </Image>
        </Button>

        <!-- Trezor -->
        <Button Width="142"
                Cursor="Hand"
                Height="151"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,260,512"
                Click="Safe_Click"
                Background="Transparent"
                Opacity="0.01"
                BorderThickness="0">

            <Image Source="pack://application:,,,/Assets/Objects/safe.png"
                   Stretch="Uniform" Height="136" Width="118"/>
        </Button>

        <!-- Poznámka -->
        <Button Width="119"
                Cursor="Hand"
                Height="78"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="963,687,0,0"
                Click="Note_Click"
                Background="Transparent"
                Opacity="0.01"
                BorderThickness="0" RenderTransformOrigin="0.5,0.5">

            <Button.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-22.155"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Button.RenderTransform>

            <Image Source="pack://application:,,,/Assets/Objects/note.png"
                   Stretch="Uniform" Height="42"/>
        </Button>

        <!-- Dialog panel -->
        <Border VerticalAlignment="Bottom"
                Height="120"
                Background="#77000000"
                CornerRadius="15"
                Margin="20"
                IsHitTestVisible="False">

            <TextBlock x:Name="DialogText"
                       Foreground="White"
                       FontSize="24"
                       Margin="30,20"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>
        </Border>

    </Grid>
</UserControl>